# ============================================================
# GitCortex Docker Build Context — 只保留构建必需文件
# 原则：白名单思维，先排除一切，再通过 !path 放行
# ============================================================

# --- 排除一切 ---
*

# --- 放行：前端构建必需 ---
!frontend/package.json
!frontend/src/
!frontend/public/
!frontend/index.html
!frontend/tsconfig.json
!frontend/tsconfig.node.json
!frontend/vite.config.ts
!frontend/postcss.config.js
!frontend/postcss.config.cjs
!frontend/tailwind.config.js
!frontend/tailwind.config.cjs
!frontend/tailwind.new.config.js
!frontend/tailwind.legacy.config.js
!frontend/.eslintrc.*

# --- 放行：根级前端配置 ---
!package.json
!pnpm-lock.yaml
!pnpm-workspace.yaml
!.npmrc

# --- 放行：共享类型 ---
!shared/

# --- 放行：Rust 构建必需 ---
!Cargo.toml
!Cargo.lock
!crates/
!proto/
!.cargo/config.toml

# --- 放行：静态资源（嵌入二进制） ---
!assets/
!crates/utils/src/api/organizations.rs

# --- 放行：Docker 自身脚本 ---
!scripts/docker/entrypoint.sh
!scripts/docker/install/

# --- 二次排除：放行目录中的垃圾 ---
**/node_modules/
**/target/
**/.git/
**/.git
**/*.log
**/*.db
**/*.db-shm
**/*.db-wal
**/dist/
**/.worktrees/
**/worktrees/
**/dev_assets/
**/.tmp/
**/tmp/
**/coverage/
**/test-results/
**/test-output/
**/playwright-report/
**/*.trace
**/*.trace.log
**/.runtime_monitor/
**/.env
**/.env.*
**/CLAUDE.md
**/AGENTS.md
**/.claude/
