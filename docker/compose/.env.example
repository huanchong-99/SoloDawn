# Reused by both install-docker.ps1 and update-docker.ps1

# Required
SOLODAWN_ENCRYPTION_KEY=your-32-char-encryption-key-here

# Optional: API token for /api routes (Docker-only variable)
SOLODAWN_DOCKER_API_TOKEN=

# AI CLI API Keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Server
PORT=23456
RUST_LOG=info

# Database (SQLite). Path is inside the container; maps to the solodawn-data volume
# mounted at /var/lib/solodawn. Override only if you relocate the DB file.
DATABASE_URL=sqlite:/data/solodawn.db

# Host <-> container workspace mapping
HOST_WORKSPACE_ROOT=../..
SOLODAWN_WORKSPACE_ROOT=/workspace
SOLODAWN_ALLOWED_ROOTS=/workspace,/var/lib/solodawn

# Optional: weak-network build profile (`official` or `china`)
SOLODAWN_BUILD_NETWORK_PROFILE=official

# Optional: prebuilt image source (pull-first strategy)
SOLODAWN_IMAGE_REGISTRY=ghcr.io
SOLODAWN_IMAGE_NAMESPACE=huanchong-99
# Pull policy: always | missing | never
SOLODAWN_IMAGE_PULL_POLICY=missing

# Optional: install AI CLIs during image build (0|1)
INSTALL_AI_CLIS=0

# Optional: auto-create up to 3 starter projects after first disclaimer acceptance (0|1)
SOLODAWN_AUTO_SETUP_PROJECTS=0
